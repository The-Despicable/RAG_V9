# RAG SaaS - Environment Configuration
# Copy this to .env and fill in your values

# ============================================
# CORE CONFIGURATION
# ============================================

ENVIRONMENT=development

APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=false

FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
CORS_ORIGINS=["http://localhost:3000"]

# ============================================
# DATABASE
# ============================================

DATABASE_URL=postgresql://postgres:password@localhost:5432/rag_saas
DB_POOL_MIN_SIZE=5
DB_POOL_MAX_SIZE=20
DB_ECHO=false

# ============================================
# REDIS / CACHING
# ============================================

REDIS_URL=redis://localhost:6379/0
REDIS_CLUSTER_ENABLED=false
CACHE_TTL_SESSIONS=3600
CACHE_TTL_BM25=86400
CACHE_TTL_EMBEDDINGS=604800

# ============================================
# VECTOR DATABASE
# ============================================

PINECONE_API_KEY=your_pincone_api_key_here
PINECONE_INDEX=rag-prod
PINECONE_ENVIRONMENT=us-east-1
EMBEDDING_DIM=768
PINECONE_NAMESPACE_PREFIX=ws_

# ============================================
# LLM PROVIDERS
# ============================================

# Primary: Ollama
OLLAMA_PROVIDER_ENABLED=true
OLLAMA_URL=https://ollama.com
OLLAMA_API_KEY=
OLLAMA_MODEL=llama3.2
OLLAMA_TEMPERATURE=0.7
OLLAMA_MAX_TOKENS=2000
OLLAMA_TIMEOUT_SECONDS=120
OLLAMA_EMBEDDING_URL=http://host.docker.internal:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_EMBEDDING_TIMEOUT=60

# Fallback: OpenRouter
OPENROUTER_PROVIDER_ENABLED=true
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-2-70b-chat
OPENROUTER_TEMPERATURE=0.7
OPENROUTER_MAX_TOKENS=2000
OPENROUTER_TIMEOUT_SECONDS=120

# Fallback: OpenAI
OPENAI_PROVIDER_ENABLED=true
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4-turbo
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=2000
OPENAI_TIMEOUT_SECONDS=30

# Provider Routing
PRIMARY_LLM_PROVIDER=ollama
FALLBACK_PROVIDERS=openrouter,openai
PROVIDER_HEALTH_CHECK_INTERVAL=300
PROVIDER_CIRCUIT_BREAKER_THRESHOLD=5
PROVIDER_CIRCUIT_BREAKER_RESET=600

# ============================================
# AUTHENTICATION & SECURITY
# ============================================

JWT_SECRET=change_this_to_a_secure_random_string_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
JWT_REFRESH_EXPIRATION_DAYS=30

PASSWORD_MIN_LENGTH=8
SESSION_TIMEOUT_MINUTES=60
MAX_SESSIONS_PER_USER=3

RATE_LIMIT_REQUESTS=30
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_BY_IP=false

CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=["GET", "POST", "PUT", "DELETE", "OPTIONS"]
CORS_ALLOW_HEADERS=["*"]
CORS_EXPOSE_HEADERS=["X-Total-Count", "X-Request-ID", "X-RateLimit-Remaining"]

# ============================================
# BILLING
# ============================================

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_DEFAULT_CURRENCY=INR

FREE_PLAN_TOKENS=50000
PRO_PLAN_TOKENS=1000000
PRO_PLAN_PRICE_INR=100
PRO_PLAN_DURATION_DAYS=30
ENTERPRISE_PLAN_TOKENS=10000000
ENTERPRISE_PLAN_PRICE_INR=1000

TOKEN_COST_INPUT=0.00001
TOKEN_COST_OUTPUT=0.00002
TOKEN_BUFFER_PERCENTAGE=5

BILLING_CYCLE_DAY=15
AUTO_RENEW_ENABLED=true

# ============================================
# DOCUMENT PROCESSING
# ============================================

MAX_FILE_MB=10
MAX_FILES_PER_BATCH=20
MAX_DOCUMENTS_PER_WORKSPACE=1000
MAX_STORAGE_GB_PER_WORKSPACE=100

CHUNK_SIZE=512
CHUNK_OVERLAP=50
MIN_CHUNK_SIZE=100
SEMANTIC_CHUNKING_ENABLED=true

ENABLE_OCR=true
ENABLE_VISION=true
ENABLE_WHISPER=true
ENABLE_YOLO=false

OCR_LANGUAGE=en
OCR_BATCH_SIZE=4
OCR_TIMEOUT_SECONDS=60

WHISPER_MODEL_SIZE=base
WHISPER_DEVICE=cpu
WHISPER_TIMEOUT_SECONDS=300

MAX_IMAGES_PER_DOCUMENT=10
MIN_IMAGE_SIZE_BYTES=1000
IMAGE_QUALITY=high

CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_TASK_TIMEOUT=600
CELERY_MAX_RETRIES=3

# ============================================
# RETRIEVAL SETTINGS
# ============================================

TOP_K_DENSE=20
TOP_K_SPARSE=20
TOP_K_FUSED=10
TOP_K_FINAL=5

HYBRID_WEIGHT_DENSE=0.6
HYBRID_WEIGHT_SPARSE=0.4

ENABLE_RERANKING=true
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANKER_BATCH_SIZE=32
RERANKER_THRESHOLD=0.3

ENABLE_METADATA_FILTERS=true
ENABLE_DATE_FILTERS=true
ENABLE_TYPE_FILTERS=true

# ============================================
# LOGGING & MONITORING
# ============================================

LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_TO_FILE=false
LOG_FILE_PATH=/var/log/rag-saas/app.log
LOG_FILE_MAX_SIZE_MB=100
LOG_FILE_BACKUP_COUNT=10

PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
PROMETHEUS_NAMESPACE=rag_saas

SENTRY_ENABLED=false
SENTRY_DSN=

# ============================================
# EXTERNAL SERVICES
# ============================================

EMAIL_PROVIDER=resend
RESEND_API_KEY=
SENDGRID_API_KEY=
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=RAG SaaS

SLACK_ENABLED=false
SLACK_WEBHOOK_URL=

POSTHOG_ENABLED=false
POSTHOG_API_KEY=
POSTHOG_API_HOST=https://app.posthog.com

# ============================================
# DEPLOYMENT
# ============================================

WORKERS=4
WORKER_THREADS=4
SOCKET_TIMEOUT=120
MAX_MEMORY_MB=2048
GRACEFUL_SHUTDOWN_TIMEOUT=30

# ============================================
# FEATURE FLAGS
# ============================================

FEATURE_HYBRID_SEARCH=true
FEATURE_RERANKING=true
FEATURE_CITATIONS=true
FEATURE_FOLLOW_UP_PROMPTS=true
FEATURE_DOCUMENT_PREVIEW=true
FEATURE_BULK_UPLOAD=true
FEATURE_WORKSPACE_TEAMS=true
FEATURE_API_KEYS=true